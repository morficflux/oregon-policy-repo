{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source-manifest.schema.json",
  "title": "Upstream source manifest",
  "type": "object",
  "required": ["sources"],
  "additionalProperties": false,
  "properties": {
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url", "sha256", "last_checked", "recheck"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "description": "Matches the content document id (or a slug for not-yet-ingested sources)" },
          "url": { "type": "string", "pattern": "^https?://" },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "last_checked": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "recheck": {
            "enum": ["weekly", "monthly", "biennial", "on_review_date"],
            "description": "Cadence hint: OAR/EO monthly (Oregon Bulletin); ORS biennial; policies/standards by printed review dates"
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
